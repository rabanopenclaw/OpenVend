{
  "components": {
    "schemas": {
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "HealthResponse": {
        "properties": {
          "service": {
            "title": "Service",
            "type": "string"
          },
          "status": {
            "title": "Status",
            "type": "string"
          },
          "timestamp": {
            "format": "date-time",
            "title": "Timestamp",
            "type": "string"
          }
        },
        "required": [
          "status",
          "service",
          "timestamp"
        ],
        "title": "HealthResponse",
        "type": "object"
      },
      "PermissionCatalog": {
        "properties": {
          "default_role": {
            "title": "Default Role",
            "type": "string"
          },
          "roles": {
            "additionalProperties": {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            "title": "Roles",
            "type": "object"
          }
        },
        "required": [
          "roles",
          "default_role"
        ],
        "title": "PermissionCatalog",
        "type": "object"
      },
      "PermissionSet": {
        "properties": {
          "roles": {
            "items": {
              "type": "string"
            },
            "title": "Roles",
            "type": "array"
          },
          "scopes": {
            "items": {
              "type": "string"
            },
            "title": "Scopes",
            "type": "array"
          }
        },
        "required": [
          "roles",
          "scopes"
        ],
        "title": "PermissionSet",
        "type": "object"
      },
      "Principal": {
        "properties": {
          "auth_strategy": {
            "title": "Auth Strategy",
            "type": "string"
          },
          "display_name": {
            "title": "Display Name",
            "type": "string"
          },
          "email": {
            "title": "Email",
            "type": "string"
          },
          "identity_id": {
            "title": "Identity Id",
            "type": "string"
          },
          "permissions": {
            "$ref": "#/components/schemas/PermissionSet"
          }
        },
        "required": [
          "identity_id",
          "email",
          "display_name",
          "auth_strategy",
          "permissions"
        ],
        "title": "Principal",
        "type": "object"
      },
      "ReadinessResponse": {
        "properties": {
          "checks": {
            "additionalProperties": {
              "type": "string"
            },
            "title": "Checks",
            "type": "object"
          },
          "service": {
            "title": "Service",
            "type": "string"
          },
          "status": {
            "title": "Status",
            "type": "string"
          }
        },
        "required": [
          "status",
          "service",
          "checks"
        ],
        "title": "ReadinessResponse",
        "type": "object"
      },
      "TokenCreateRequest": {
        "properties": {
          "expires_in_days": {
            "default": 30,
            "maximum": 365.0,
            "minimum": 1.0,
            "title": "Expires In Days",
            "type": "integer"
          },
          "name": {
            "maxLength": 80,
            "minLength": 3,
            "title": "Name",
            "type": "string"
          },
          "scopes": {
            "items": {
              "type": "string"
            },
            "minItems": 1,
            "title": "Scopes",
            "type": "array"
          }
        },
        "required": [
          "name",
          "scopes"
        ],
        "title": "TokenCreateRequest",
        "type": "object"
      },
      "TokenCreateResponse": {
        "properties": {
          "audit_event": {
            "additionalProperties": {
              "type": "string"
            },
            "title": "Audit Event",
            "type": "object"
          },
          "expires_at": {
            "format": "date-time",
            "title": "Expires At",
            "type": "string"
          },
          "name": {
            "title": "Name",
            "type": "string"
          },
          "scopes": {
            "items": {
              "type": "string"
            },
            "title": "Scopes",
            "type": "array"
          },
          "token": {
            "title": "Token",
            "type": "string"
          },
          "token_type": {
            "default": "agent",
            "title": "Token Type",
            "type": "string"
          }
        },
        "required": [
          "token",
          "name",
          "scopes",
          "expires_at",
          "audit_event"
        ],
        "title": "TokenCreateResponse",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      }
    }
  },
  "info": {
    "summary": "ERP authorization, roles, scopes, and agent-token foundation.",
    "title": "OpenVend Authorization Adapter",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/health": {
      "get": {
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Health",
        "tags": [
          "system"
        ]
      }
    },
    "/me": {
      "get": {
        "operationId": "me_me_get",
        "parameters": [
          {
            "in": "header",
            "name": "X-OpenVend-Identity-Id",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "X-Openvend-Identity-Id"
            }
          },
          {
            "in": "header",
            "name": "X-OpenVend-Email",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "X-Openvend-Email"
            }
          },
          {
            "in": "header",
            "name": "X-OpenVend-Display-Name",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "X-Openvend-Display-Name"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Principal"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Me",
        "tags": [
          "identity"
        ]
      }
    },
    "/permissions": {
      "get": {
        "operationId": "permissions_permissions_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PermissionCatalog"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Permissions",
        "tags": [
          "authorization"
        ]
      }
    },
    "/ready": {
      "get": {
        "operationId": "ready_ready_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReadinessResponse"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Ready",
        "tags": [
          "system"
        ]
      }
    },
    "/tokens": {
      "post": {
        "operationId": "create_token_tokens_post",
        "parameters": [
          {
            "in": "header",
            "name": "X-OpenVend-Identity-Id",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "X-Openvend-Identity-Id"
            }
          },
          {
            "in": "header",
            "name": "X-OpenVend-Email",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "X-Openvend-Email"
            }
          },
          {
            "in": "header",
            "name": "X-OpenVend-Display-Name",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "X-Openvend-Display-Name"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TokenCreateRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenCreateResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Create Token",
        "tags": [
          "tokens"
        ]
      }
    }
  }
}
