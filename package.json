{
  "name": "openvend",
  "version": "0.1.0",
  "private": true,
  "description": "Source-available modular ERP platform",
  "workspaces": [
    "apps/web",
    "packages/api-client"
  ],
  "scripts": {
    "check": "npm run lint --workspaces --if-present && npm run typecheck --workspaces --if-present && npm run test --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "openapi:export": "sh scripts/export_openapi.sh",
    "openapi:authz": "npm run openapi:export",
    "openapi:clients": "npm run openapi:export && npm run generate --workspace @openvend/api-client",
    "compose:config": "docker compose config --quiet",
    "license:check": "node scripts/check_dependency_policy.mjs && node scripts/check_node_licenses.mjs",
    "license:node": "node scripts/check_node_licenses.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "license-checker-rseidelsohn": "4.4.2"
  }
}
