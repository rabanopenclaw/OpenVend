OPENVEND_PUBLIC_BASE_URL=http://localhost:8088
OPENVEND_ENV=development
OPENVEND_HTTP_BIND=127.0.0.1
OPENVEND_HTTP_PORT=8088
OPENVEND_HTTPS_BIND=127.0.0.1
OPENVEND_HTTPS_PORT=8443
OPENVEND_TRAEFIK_DASHBOARD_PORT=18088

POSTGRES_USER=openvend
POSTGRES_PASSWORD=openvend-dev-password
POSTGRES_DB=openvend_admin

KRATOS_DSN=postgres://openvend:openvend-dev-password@postgres:5432/kratos?sslmode=disable
KRATOS_PUBLIC_URL=http://localhost:8088/auth
KRATOS_ADMIN_URL=http://kratos:4434
KRATOS_COOKIE_SECRET=replace-with-at-least-32-characters
KRATOS_CIPHER_SECRET=replace-with-32-character-secret

AUTHZ_SERVICE_TOKEN_SECRET=replace-with-dev-secret
AUTHZ_DEV_AUTH_ENABLED=false
AUTHZ_DEMO_IDENTITY_ID=dev-admin
AUTHZ_DEMO_EMAIL=admin@example.com
AUTHZ_DEMO_DISPLAY_NAME="OpenVend Admin"
AUTHZ_DEMO_ROLE=owner

CONTACTS_DATABASE_URL=postgresql+pg8000://openvend:openvend-dev-password@postgres:5432/contacts

VITE_API_BASE_URL=/api/v1
VITE_AUTH_BASE_URL=/auth
